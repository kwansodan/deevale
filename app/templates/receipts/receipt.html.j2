<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<style>
  body { font-family: sans-serif; color: #1A1D21; }
  h1 { color: #131A24; font-family: Georgia, 'Times New Roman', serif; font-weight: 600; }
  table { width: 100%; border-collapse: collapse; margin-top: 1em; }
  th, td { text-align: left; padding: 8px; border-bottom: 1px solid #ddd; }
  .total-row td { font-weight: bold; border-top: 2px solid #131A24; }
</style>
</head>
<body>
  <h1>Deevale GH Receipt</h1>
  <p>Invoice {{ invoice.invoice_number }}</p>
  <p>Paid: {{ invoice.paid_at }}</p>
  <table>
    <thead>
      <tr><th>Item</th><th>Amount ({{ invoice.currency }})</th></tr>
    </thead>
    <tbody>
      {% for line in invoice.line_items %}
      <tr><td>{{ line.label }}</td><td>{{ "%.2f"|format(line.amount_minor / 100) }}</td></tr>
      {% endfor %}
      <tr class="total-row">
        <td>Total</td>
        <td>{{ "%.2f"|format(invoice.total_minor / 100) }}</td>
      </tr>
    </tbody>
  </table>
</body>
</html>
