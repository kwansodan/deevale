VITE_API_BASE_URL=http://localhost:5000
VITE_SOCKET_URL=http://localhost:5000

# ---------------------------------------------------------------------------
# Landing page figures (set these in the Vercel dashboard, per environment).
#
# All VITE_ vars are baked in at BUILD time and are PUBLIC — visible to anyone
# who opens devtools. Never put a secret here. Changing one needs a redeploy,
# not a restart.
#
# Anything left blank renders as "Request a quote" / "Confirm with us" rather
# than a made-up number, and empty trust signals hide their whole section.
# Leaving a value unset is always safer than guessing at it.
# ---------------------------------------------------------------------------

# Who we are — the credibility strip. Omit all three and the strip disappears.
VITE_COMPANY_LEGAL_NAME=
VITE_COMPANY_REG_NUMBER=
VITE_COMPANY_ADDRESS=
VITE_COMPANY_EMAIL=
VITE_COMPANY_PHONE=
# Digits only, international format, no "+" — used to build a wa.me link.
VITE_COMPANY_WHATSAPP=
VITE_YEARS_OPERATING=
VITE_CASES_COMPLETED=
VITE_DPC_REGISTRATION_NUMBER=

# All-in indicative prices, government fees included. Free-form strings so you
# can write "from GHS 2,500" or "GHS 2,500 – 4,000".
VITE_PRICE_LTD_SHARES=
VITE_PRICE_SOLE_PROP=
VITE_PRICE_PARTNERSHIP=
VITE_PRICE_LTD_GUARANTEE=
VITE_PRICE_EXTERNAL_COMPANY=
VITE_PRICE_FOREIGN_LTD=

# Typical turnaround, e.g. "5–7 business days".
VITE_TIMELINE_LTD_SHARES=
VITE_TIMELINE_SOLE_PROP=
VITE_TIMELINE_PARTNERSHIP=
VITE_TIMELINE_LTD_GUARANTEE=
VITE_TIMELINE_EXTERNAL_COMPANY=
VITE_TIMELINE_FOREIGN_LTD=

# GIPC minimum equity thresholds. Set by statute and amended over time —
# verify against the current GIPC Act before publishing. A wrong figure here
# is one a client budgets against.
VITE_GIPC_CAPITAL_JOINT_VENTURE=
VITE_GIPC_CAPITAL_WHOLLY_FOREIGN=
VITE_GIPC_CAPITAL_TRADING=
VITE_GIPC_FEE=

# Recurring services.
VITE_PRICE_COMPLIANCE_MONTHLY=
VITE_PRICE_COMPLIANCE_ANNUAL=
VITE_PRICE_REGISTERED_ADDRESS=

# Legal pages. Each link only renders once its URL is set.
VITE_TERMS_URL=
VITE_PRIVACY_URL=
VITE_REFUND_URL=
